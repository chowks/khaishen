---
import Layout from '../layouts/Layout.astro';
import Card from '../components/Card.astro';
import MuiLogo from './mui-logo.svg';
import { Icon } from 'astro-icon';
import Navbar, { NavigationProps } from 'src/components/Navbar.astro';
import IconWithFrame from 'src/components/IconWithFrame.astro';

const navigations: NavigationProps[] = [
  { href: '/about', label: 'About' },
  { href: '/contact', label: 'Contact' },
];

const icons = [
  'css-logo',
  'go-logo',
  'html-logo',
  'js-logo',
  'mui-logo',
  'react-logo',
  'ts-logo',
  'tw-logo',
];
---

<Layout title="Welcome to Astro.">
  <Navbar leftNavs={navigations} />
  <main>
    <div
      class="relative isolate px-8 lg:px-20 h-screen flex justify-center lg:flex-row flex-col-reverse items-center"
    >
      <!-- left big title -->
      <div class="text-left">
        <h1 class="text-4xl lg:text-8xl font-bold text-white sm:text-6xl">
          Data to enrich your online business
        </h1>
        <p class="mt-6 text-lg leading-8 text-slate-300 w-3/4">
          Anim aute id magna aliqua ad ad non deserunt sunt. Qui irure qui lorem
          cupidatat commodo. Elit sunt amet fugiat veniam occaecat fugiat
          aliqua.
        </p>
      </div>

      <!-- right logo -->
      <div class="text-center"></div>
    </div>

    <!-- tech stack + language -->
    <div class="flex justify-evenly">
      {icons.map((icon) => <IconWithFrame icon={icon} />)}
    </div>
    <!-- about me + life photo -->

    <!-- portfolio showcase summary -->

    <!-- contact me summary -->

    <!-- footer -->
  </main>
</Layout>
